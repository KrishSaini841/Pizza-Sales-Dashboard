            <run fontalignment='1' fontcolor='#ff9d9a' fontname='Segoe UI Semibold' fontsize='8'>Significant variations in weekly orders</run>
            <run fontalignment='1' fontcolor='#e6e6e6' fontname='Segoe UI Semibold' fontsize='8'>, with highest</run>
            <run fontalignment='1'>Æ&#10;</run>
